# ============================================================
# Creator Command — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Found in: supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Meta / Facebook / Instagram (required for IG connect) ───
# Found in: developers.facebook.com → Your App → Settings → Basic
VITE_META_APP_ID=your_meta_app_id

# ── Threads (required for Threads connect) ──────────────────
VITE_THREADS_APP_ID=your_threads_app_id

# ── OAuth Redirect URIs ──────────────────────────────────────
# Must match EXACTLY what's registered in each platform's dev console.
# For production: replace localhost with your deployed domain.
VITE_META_REDIRECT_URI=https://yourdomain.com/auth/meta/callback
VITE_THREADS_REDIRECT_URI=https://yourdomain.com/auth/threads/callback

# ── TikTok (required for TikTok connect) ────────────────────
# Found in: developers.tiktok.com → Your App → Manage Apps
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key
VITE_TIKTOK_REDIRECT_URI=https://yourdomain.com/settings?platform=tiktok

# ── YouTube / Google (required for YouTube connect) ─────────
# Found in: console.cloud.google.com → APIs & Services → Credentials
VITE_YOUTUBE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
VITE_YOUTUBE_REDIRECT_URI=https://yourdomain.com/settings?platform=youtube

# ── Stripe (optional — enables paywall upgrade button) ──────
# Create a Payment Link at stripe.com/payment-links
# Leave blank to fall back to mailto: upgrade email
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_payment_link

# ============================================================
# Supabase Edge Function Secrets (set via Supabase dashboard)
# These are NOT frontend env vars — set them at:
# supabase.com → Project → Edge Functions → Manage secrets
# OR via: supabase secrets set KEY=value
# ============================================================
#
# ANTHROPIC_API_KEY=sk-ant-...        ← Required for ALL AI features
# META_APP_SECRET=...                 ← Required for Instagram OAuth
# THREADS_APP_SECRET=...              ← Required for Threads OAuth
# TIKTOK_CLIENT_SECRET=...            ← Required for TikTok OAuth
# YOUTUBE_CLIENT_SECRET=...           ← Required for YouTube OAuth
# SUPABASE_SERVICE_ROLE_KEY=...       ← Auto-available in edge functions
